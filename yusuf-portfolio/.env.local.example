# Copy to .env.local and fill in (never commit .env.local)

# Supabase: Project URL (Settings → API, or Data API overview). Same as https://<project-ref>.supabase.co — not the /rest/v1 row.
# Project ref from dashboard: ndjnnofjxdimcslrpggs
NEXT_PUBLIC_SUPABASE_URL=https://ndjnnofjxdimcslrpggs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Groq (LLM)
GROQ_API_KEY=

# Resend (email)
RESEND_API_KEY=

# Random 32+ character string for JWT signing (e.g. openssl rand -base64 32)
NEXTAUTH_SECRET=
